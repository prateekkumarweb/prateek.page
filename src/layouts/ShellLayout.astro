---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string | undefined;
}

const {
  title = "Prateek Kumar - Shell Mode",
  description = "Prateek Kumar | Software Engineer | Rust and JavaScript",
  image = "https://static.prateek.page/images/profile.jpg",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#123456" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Prateek" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- JetBrains Mono Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={Astro.url} />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="shell-theme">
    <div class="min-h-screen bg-shell-bg text-shell-text">
      <!-- Scan line effect -->
      <div class="scanlines pointer-events-none fixed inset-0 z-50"></div>

      <!-- CRT glow effect -->
      <div class="crt-glow pointer-events-none fixed inset-0 z-40"></div>

      <div class="relative z-10">
        <slot />
      </div>
    </div>
  </body>
</html>
