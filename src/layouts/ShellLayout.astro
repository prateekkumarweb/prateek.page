---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string | undefined;
}

const {
  title = "Prateek Kumar - Shell Mode",
  description = "Prateek Kumar | Software Engineer | Rust and JavaScript",
  image = "https://static.prateek.page/images/profile.jpg",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#123456" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Prateek" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- JetBrains Mono Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={Astro.url} />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="shell-theme">
    <div class="min-h-screen bg-[#0a0a0a] text-[#e0e0e0]">
      <!-- Scan line effect -->
      <div class="scanlines pointer-events-none fixed inset-0 z-50"></div>

      <!-- CRT glow effect -->
      <div class="crt-glow pointer-events-none fixed inset-0 z-40"></div>

      <div class="relative z-10">
        <slot />
      </div>
    </div>

    <style is:global>
      .shell-theme {
        font-family: "JetBrains Mono", "Courier New", monospace;
      }

      /* Scanline effect */
      .scanlines {
        background: linear-gradient(
          to bottom,
          transparent 50%,
          rgba(0, 255, 0, 0.02) 51%
        );
        background-size: 100% 4px;
        animation: scanline 8s linear infinite;
      }

      @keyframes scanline {
        0% {
          transform: translateY(0);
        }
        100% {
          transform: translateY(4px);
        }
      }

      /* CRT glow effect */
      .crt-glow {
        background: radial-gradient(
          ellipse at center,
          transparent 0%,
          rgba(18, 52, 86, 0.1) 100%
        );
      }

      /* Text shadow for CRT effect */
      .shell-theme {
        text-shadow: 0 0 5px rgba(224, 224, 224, 0.3);
      }

      /* Hide scrollbar but keep functionality */
      #terminal-output::-webkit-scrollbar {
        width: 8px;
      }

      #terminal-output::-webkit-scrollbar-track {
        background: #0a0a0a;
      }

      #terminal-output::-webkit-scrollbar-thumb {
        background: #123456;
        border-radius: 4px;
      }

      #terminal-output::-webkit-scrollbar-thumb:hover {
        background: #1a4a6a;
      }
    </style>
  </body>
</html>
