---
import ShellLayout from "@/layouts/ShellLayout.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("post"))
  .sort((a, b) => {
    if (a.data.date < b.data.date) return -1;
    if (a.data.date > b.data.date) return 1;
    return 0;
  })
  .reverse();

// Serialize posts data for client-side JavaScript
const postsData = allPosts.map((post) => ({
  slug: post.slug,
  title: post.data.title,
  date: post.data.date.toISOString(),
  tags: post.data.tags || [],
}));
---

<ShellLayout>
  <!-- Status Bar (fixed at top) -->
  <div
    class="fixed top-0 left-0 right-0 z-50 text-xs px-4 py-1 bg-shell-primary text-white flex justify-between items-center"
  >
    <div class="flex gap-4 items-center">
      <span class="font-bold">PRATEEK.PAGE</span>
      <span class="text-shell-text-dimmer hidden sm:inline">|</span>
      <span id="status-dir" class="hidden sm:inline">~/</span>
      <span id="status-branch" class="text-shell-accent hidden sm:inline"
        >⎇ main</span
      >
    </div>
    <div class="flex gap-4">
      <span id="status-time"></span>
    </div>
  </div>

  <!-- Terminal Content -->
  <div
    class="pt-8 p-4 min-h-screen font-mono text-sm select-text [&_a]:underline"
    id="terminal-container"
  >
    <div id="terminal-output" class="[&_a]:underline">
      <!-- Welcome message and command history will be added here -->
    </div>

    <!-- Current Input Line -->
    <div class="flex items-center" id="input-line">
      <span class="text-shell-blue" id="prompt-user">user@prateek.page</span
      ><span class="text-shell-blue-light">:</span><span
        class="text-shell-accent"
        id="prompt-dir">~</span
      ><span class="text-white">$&nbsp;</span><input
        type="text"
        id="command-input"
        class="flex-1 bg-transparent text-white font-mono p-0 m-0 outline-none focus:outline-none border-none focus:border-none focus:ring-0"
        autocomplete="off"
        spellcheck="false"
        autofocus
      />
    </div>
  </div>

  <script is:inline define:vars={{ postsData }}>
    // Terminal state
    let currentDir = "~";
    let commandHistory = [];
    let historyIndex = -1;
    let fileSystem = {
      "~": {
        type: "dir",
        contents: {
          "profile.txt": { type: "file" },
          "projects.txt": { type: "file" },
          "education.txt": { type: "file" },
          "publications.txt": { type: "file" },
          "contact.txt": { type: "file" },
          ".secrets": { type: "file" },
          post: { type: "dir", contents: {} },
        },
      },
    };

    // Add blog posts to post directory
    postsData.forEach((post) => {
      fileSystem["~"].contents["post"].contents[`${post.slug}.md`] = {
        type: "file",
        data: post,
      };
    });

    // DOM elements
    const terminalOutput = document.getElementById("terminal-output");
    const terminalContainer = document.getElementById("terminal-container");
    const commandInput = document.getElementById("command-input");
    const inputLine = document.getElementById("input-line");
    const statusDir = document.getElementById("status-dir");
    const promptDir = document.getElementById("prompt-dir");
    const promptUser = document.getElementById("prompt-user");
    const statusTime = document.getElementById("status-time");

    // Update time in status bar
    function updateTime() {
      const now = new Date();
      statusTime.textContent = now.toLocaleTimeString();
    }
    setInterval(updateTime, 1000);
    updateTime();

    // Add output to terminal
    function addOutput(html, className = "") {
      const div = document.createElement("div");
      div.className = className;
      div.innerHTML = html;
      terminalOutput.appendChild(div);
      // Scroll to bottom
      window.scrollTo(0, document.body.scrollHeight);
    }

    // Add command to terminal output
    function addCommandToOutput(cmd) {
      const cmdDiv = document.createElement("div");
      cmdDiv.className = "mb-2";
      cmdDiv.innerHTML = `<span class="text-shell-blue">user@prateek.page</span><span class="text-shell-blue-light">:</span><span class="text-shell-accent">${currentDir}</span><span class="text-white">$&nbsp;</span>${cmd}`;
      terminalOutput.appendChild(cmdDiv);
    }

    // Update prompt directory
    function updatePrompt() {
      promptDir.textContent = currentDir;
      statusDir.textContent = currentDir === "~" ? "~/" : currentDir + "/";
    }

    // Welcome message
    function showWelcome() {
      const welcome = `
<div class="mb-4 text-shell-text">
<div class="text-shell-accent font-bold text-lg mb-2">Welcome to the interactive shell!</div>

Type <span class="text-shell-blue font-bold">help</span> to see available commands.
Type <span class="text-shell-blue font-bold">ls</span> to list files and directories.

<div class="text-shell-text-dimmer mt-2">Hint: Try some easter eggs like 'whoami', 'sudo', or 'hack'</div>
</div>
`;
      addOutput(welcome);
    }

    // Commands implementation
    const commands = {
      help: () => {
        return `
<div class="space-y-1">
  <div class="text-white font-bold mb-2">Available Commands:</div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-shell-text">
    <div><span class="text-shell-blue font-bold">help</span> - Show this help message</div>
    <div><span class="text-shell-blue font-bold">ls</span> - List directory contents</div>
    <div><span class="text-shell-blue font-bold">cat [file]</span> - Display file contents</div>
    <div><span class="text-shell-blue font-bold">cd [dir]</span> - Change directory</div>
    <div><span class="text-shell-blue font-bold">pwd</span> - Print working directory</div>
    <div><span class="text-shell-blue font-bold">clear</span> - Clear terminal</div>
    <div><span class="text-shell-blue font-bold">whoami</span> - Display current user</div>
    <div><span class="text-shell-blue font-bold">neofetch</span> - System information</div>
    <div><span class="text-shell-blue font-bold">matrix</span> - Enter the matrix</div>
    <div><span class="text-shell-blue font-bold">cowsay [msg]</span> - ASCII cow says something</div>
    <div><span class="text-shell-blue font-bold">hack</span> - Initiate hacking sequence</div>
    <div><span class="text-shell-blue font-bold">sudo [cmd]</span> - Execute as superuser</div>
    <div><span class="text-shell-blue font-bold">exit</span> - Exit shell mode</div>
  </div>
</div>`;
      },

      ls: (args) => {
        let targetDir = currentDir;

        // Handle ls post or ls post/
        if (args[0]) {
          const target = args[0].replace(/\/$/, ""); // Remove trailing slash
          if (target === "post" && currentDir === "~") {
            targetDir = "~/post";
          } else {
            return `<div class="text-red-500">ls: cannot access '${args[0]}': No such file or directory</div>`;
          }
        }

        let dir;
        if (targetDir === "~") {
          dir = fileSystem["~"];
        } else if (targetDir === "~/post") {
          dir = fileSystem["~"].contents["post"];
        }

        const contents = Object.keys(dir.contents);

        let output = '<div class="space-y-1">';
        contents.forEach((name) => {
          const item = dir.contents[name];
          if (item.type === "dir") {
            output += `<div class="text-shell-blue font-bold">${name}/</div>`;
          } else {
            output += `<div class="text-shell-accent">${name}</div>`;
          }
        });
        output += "</div>";
        return output;
      },

      pwd: () => {
        return `<div class="text-white">${currentDir}</div>`;
      },

      cd: (args) => {
        const target = args[0];
        if (!target || target === "~") {
          currentDir = "~";
          updatePrompt();
          return "";
        }

        if (target === "post" && currentDir === "~") {
          currentDir = "~/post";
          updatePrompt();
          return "";
        }

        if (target === ".." && currentDir === "~/post") {
          currentDir = "~";
          updatePrompt();
          return "";
        }

        return `<div class="text-red-500">cd: ${target}: No such directory</div>`;
      },

      cat: (args) => {
        if (!args[0]) {
          return '<div class="text-red-500">cat: missing file operand</div>';
        }

        const filename = args[0];

        if (filename === "profile.txt") {
          return `
<div class="flex gap-4 flex-col md:flex-row items-start">
  <img src="https://static.prateek.page/images/profile.jpg" alt="Prateek Kumar" class="w-32 h-32 rounded-lg border-2 border-shell-blue" />
  <div class="space-y-2 flex-1">
    <div class="text-white text-xl font-bold">Prateek Kumar</div>
    <div class="text-shell-text-dim">Software Engineer</div>
    <div class="text-shell-text-dimmer">Specialization: <span class="text-shell-blue">Rust</span> | <span class="text-shell-accent">JavaScript</span></div>
  </div>
</div>`;
        }

        if (filename === "projects.txt") {
          return `
<div class="space-y-3">
  <div class="">
    <div class="font-bold text-white">Open-WBO-Inc</div>
    <div class="text-shell-text-dim text-sm">Open-WBO-Inc is a partial incomplete MaxSAT solver built on top of Open-WBO. Open-WBO is an extensible and modular open-source MaxSAT solver. Open-WBO-Inc got 1st place in 60s timeout track and 2nd place in 300s timeout track at MaxSAT Evaluations 2018.</div>
    <a href="https://github.com/sbjoshi/Open-WBO-Inc" target="_blank" class="text-shell-accent text-sm">[GitHub]</a>
  </div>
  <div class="">
    <div class="font-bold text-white">UTVPI-OA</div>
    <div class="text-shell-text-dim text-sm">Implementation of algorithms to compute overapproximations of polyhedra based on Linear Programming and Fourier-Motzkin elimination.</div>
    <a href="https://github.com/IITH-Compilers/UTVPI-OA" target="_blank" class="text-shell-accent text-sm">[GitHub]</a>
  </div>
  <div class="">
    <div class="font-bold text-white">Timetabler</div>
    <div class="text-shell-text-dim text-sm">A customizable timetabling software for educational institutions that encodes timetabling constraints as a SAT formula and solves them using a MaxSAT solver.</div>
    <a href="https://github.com/sukrutrao/Timetabler" target="_blank" class="text-shell-accent text-sm">[GitHub]</a>
    <a href="https://timetabler.readthedocs.io/" target="_blank" class="text-shell-accent text-sm ml-2">[Docs]</a>
  </div>
  <div class="">
    <div class="font-bold text-white">Autojudge</div>
    <div class="text-shell-text-dim text-sm">An implementation of an online judge that can be used for conducting programming contests as well as managing assignments in a university.</div>
    <a href="https://github.com/vbsinha/autojudge" target="_blank" class="text-shell-accent text-sm">[GitHub]</a>
    <a href="https://autojudge.readthedocs.io/" target="_blank" class="text-shell-accent text-sm ml-2">[Docs]</a>
  </div>
</div>`;
        }

        if (filename === "education.txt") {
          return `
<div class="">
  <div class="text-white font-bold">B. Tech. (Honors) in Computer Science and Engineering</div>
  <div class="text-shell-text-dim">Indian Institute of Technology Hyderabad, India</div>
  <div class="text-shell-text-dimmer">2015-2019</div>
</div>`;
        }

        if (filename === "publications.txt") {
          return `
<div class="space-y-3 text-xs">
  <div class="">
    <div class="text-white font-semibold">Open-WBO-Inc: Approximation Strategies for Incomplete Weighted MaxSAT.</div>
    <div class="text-shell-text-dimmer">Saurabh Joshi, Prateek Kumar, Sukrut Rao, Ruben Martins</div>
    <div class="text-shell-blue">JSAT 2019 (vol. 11)</div>
    <a href="https://content.iospress.com/download/journal-on-satisfiability-boolean-modeling-and-computation/sat190118?id=journal-on-satisfiability-boolean-modeling-and-computation%2Fsat190118" target="_blank" class="text-shell-accent">[PDF]</a>
  </div>
  <div class="">
    <div class="text-white font-semibold">An analysis of executable size reduction by LLVM passes.</div>
    <div class="text-shell-text-dimmer">Shalini Jain, Utpal Bora, Prateek Kumar, Vaibhav B. Sinha, Suresh Purini, Ramakrishna Upadrasta</div>
    <div class="text-shell-blue">CSIT 2019</div>
    <a href="https://link.springer.com/article/10.1007%2Fs40012-019-00248-5" target="_blank" class="text-shell-accent">[PDF]</a>
  </div>
  <div class="">
    <div class="text-white font-semibold">Approximation Strategies for Incomplete MaxSAT.</div>
    <div class="text-shell-text-dimmer">Saurabh Joshi, Prateek Kumar, Ruben Martins, Sukrut Rao</div>
    <div class="text-shell-blue">CP 2018</div>
    <a href="https://link.springer.com/content/pdf/10.1007/978-3-319-98334-9_15.pdf" target="_blank" class="text-shell-accent">[PDF]</a>
  </div>
  <div class="mt-2">
    <a href="https://scholar.google.co.in/citations?user=M1NFyhAAAAAJ&hl=en" target="_blank" class="text-shell-accent">[Google Scholar]</a>
  </div>
</div>`;
        }

        if (filename === "contact.txt") {
          return `
<div class="space-y-2">
  <div class="text-white font-bold">Contact Information:</div>
  <div><a href="https://github.com/prateekkumarweb" target="_blank" class="text-shell-accent">GitHub: @prateekkumarweb</a></div>
  <div><a href="https://bsky.app/profile/prateek.page" target="_blank" class="text-shell-accent">Bluesky: @prateek.page</a></div>
  <div><a href="https://www.linkedin.com/in/prateekkumarweb/" target="_blank" class="text-shell-accent">LinkedIn: prateekkumarweb</a></div>
</div>`;
        }

        if (filename === ".secrets") {
          return `
<div class="text-shell-accent">
  🔒 You found the secret file!
  
  Secret: I actually prefer tabs over spaces... just kidding! 😄
</div>`;
        }

        // Check if it's a blog post in ~/post directory
        if (currentDir === "~/post" && filename.endsWith(".md")) {
          const postSlug = filename.replace(".md", "");
          const post = postsData.find((p) => p.slug === postSlug);
          if (post) {
            const date = new Date(post.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            });
            return `
<div class="space-y-2">
  <div class="text-white text-xl font-bold">${post.title}</div>
  <div class="text-shell-text-dimmer text-sm">${date}</div>
  <div class="mt-2">
    <a href="/post/${post.slug}/" class="text-shell-accent">[Read full post]</a>
  </div>
</div>`;
          }
        }

        return `<div class="text-red-500">cat: ${filename}: No such file or directory</div>`;
      },

      clear: () => {
        terminalOutput.innerHTML = "";
        return null;
      },

      whoami: () => {
        return `<div class="text-white">user</div>`;
      },

      neofetch: () => {
        return `
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <div class="text-shell-blue text-xs">
<pre>
      ___     
     (o o)    
    (  V  )   
    /--m-m-   
</pre>
  </div>
  <div class="space-y-1 text-sm text-shell-text">
    <div><span class="text-shell-blue font-bold">User:</span> user@prateek.page</div>
    <div><span class="text-shell-blue font-bold">Host:</span> prateek.page</div>
    <div><span class="text-shell-blue font-bold">Shell:</span> interactive-shell</div>
    <div><span class="text-shell-blue font-bold">Terminal:</span> web-terminal</div>
    <div><span class="text-shell-blue font-bold">Uptime:</span> ${Math.floor(performance.now() / 1000)}s</div>
  </div>
</div>`;
      },

      cowsay: (args) => {
        const message = args.join(" ") || "Hello!";
        const length = message.length;
        return `
<div class="text-shell-accent text-xs">
<pre>
 ${"_".repeat(length + 2)}
< ${message} >
 ${"-".repeat(length + 2)}
        \\   ^__^
         \\  (oo)\\_______
            (__)\\       )\\/\\
                ||----w |
                ||     ||
</pre>
</div>`;
      },

      sudo: (args) => {
        const cmd = args.join(" ");
        if (cmd.includes("rm -rf")) {
          return `
<div class="text-red-500">
  <div>⚠️  CRITICAL WARNING ⚠️</div>
  <div class="my-2">Deleting everything...</div>
  <div>Just kidding! Nice try though 😄</div>
  <div class="mt-2 text-shell-text-dimmer">(You need REAL root access for that)</div>
</div>`;
        }
        return `
<div class="text-red-500">
  [sudo] password for user: 
  <div class="mt-1">Sorry, user is not in the sudoers file. This incident will be reported.</div>
  <div class="text-shell-text-dimmer text-xs mt-1">(Just kidding, you can't actually sudo here 😄)</div>
</div>`;
      },

      hack: () => {
        return `
<div class="text-shell-accent">
  <div>Initiating hacking sequence...</div>
  <div class="mt-2">
    <div>▓▓▓▓▓▓▓▓▓▓ 100%</div>
  </div>
  <div class="mt-2 text-shell-blue font-bold">
    <div>ACCESS GRANTED</div>
    <div>Welcome, hackerman!</div>
  </div>
  <div class="mt-2 text-shell-text-dimmer text-xs">
    (Not really, this is just for fun 😄)
  </div>
</div>`;
      },

      matrix: () => {
        return `
<div class="text-shell-blue text-xs">
  <div class="text-shell-accent">Entering the Matrix...</div>
  <div class="mt-2 overflow-hidden h-32 relative">
    <div class="animate-scroll">
      <div>01010111 01100101 01101100 01100011</div>
      <div>01101111 01101101 01100101 00100000</div>
      <div>01110100 01101111 00100000 01110100</div>
      <div>01101000 01100101 00100000 01001101</div>
      <div>01100001 01110100 01110010 01101001</div>
      <div>01111000 00100001</div>
    </div>
  </div>
  <div class="mt-2 text-white">Welcome to the Matrix!</div>
</div>`;
      },

      exit: () => {
        window.location.href = "/";
        return '<div class="text-shell-accent">Exiting shell mode...</div>';
      },

      echo: (args) => {
        return `<div class="text-white">${args.join(" ")}</div>`;
      },
    };

    // Handle command execution
    function executeCommand(input) {
      const trimmed = input.trim();
      if (!trimmed) return;

      addCommandToOutput(trimmed);
      commandHistory.push(trimmed);
      historyIndex = commandHistory.length;

      const [cmd, ...args] = trimmed.split(" ");

      if (commands[cmd]) {
        const output = commands[cmd](args);
        if (output !== null && output !== "") {
          addOutput(output, "mb-4");
        }
      } else {
        addOutput(
          `<div class="text-red-500">Command not found: ${cmd}. Type 'help' for available commands.</div>`,
          "mb-4",
        );
      }
    }

    // Handle keyboard input
    commandInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        executeCommand(commandInput.value);
        commandInput.value = "";
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          commandInput.value = commandHistory[historyIndex];
        }
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        if (historyIndex < commandHistory.length - 1) {
          historyIndex++;
          commandInput.value = commandHistory[historyIndex];
        } else {
          historyIndex = commandHistory.length;
          commandInput.value = "";
        }
      } else if (e.key === "Tab") {
        e.preventDefault();
        // Simple autocomplete for commands
        const partial = commandInput.value;
        const matches = Object.keys(commands).filter((cmd) =>
          cmd.startsWith(partial),
        );
        if (matches.length === 1) {
          commandInput.value = matches[0];
        }
      }
    });

    // Keep focus on input when clicking in terminal area (not on links/text)
    terminalContainer.addEventListener("click", (e) => {
      // Don't refocus if clicking on a link or selecting text
      if (e.target.tagName !== "A" && window.getSelection().toString() === "") {
        commandInput.focus();
      }
    });

    // Initialize terminal
    showWelcome();
  </script>
</ShellLayout>
