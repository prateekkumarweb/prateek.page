---
import ShellLayout from "@/layouts/ShellLayout.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("post"))
  .sort((a, b) => {
    if (a.data.date < b.data.date) return -1;
    if (a.data.date > b.data.date) return 1;
    return 0;
  })
  .reverse();

// Serialize posts data for client-side JavaScript
const postsData = allPosts.map((post) => ({
  title: post.data.title,
  date: post.data.date.toISOString(),
  tags: post.data.tags || [],
}));
---

<ShellLayout>
  <!-- Status Bar (fixed at top) -->
  <div
    class="fixed top-0 left-0 right-0 z-50 text-xs px-4 py-1 bg-shell-primary text-white flex justify-between items-center"
  >
    <div class="flex gap-4 items-center">
      <span class="font-bold">PRATEEK.PAGE</span>
      <span class="text-shell-text-dimmer hidden sm:inline">|</span>
      <span id="status-dir" class="hidden sm:inline">~/</span>
      <span id="status-branch" class="text-shell-accent hidden sm:inline"
        >⎇ main</span
      >
    </div>
    <div class="flex gap-4">
      <span id="status-time"></span>
    </div>
  </div>

  <!-- Terminal Content -->
  <div
    class="pt-8 p-4 min-h-screen font-mono text-sm select-text [&_a]:underline"
    id="terminal-container"
  >
    <div id="terminal-output" class="[&_a]:underline">
      <!-- Welcome message and command history will be added here -->
    </div>

    <!-- Current Input Line -->
    <div class="flex items-center" id="input-line">
      <span class="text-shell-blue" id="prompt-user">user@prateek.page</span
      ><span class="text-shell-blue-light">:</span><span
        class="text-shell-accent"
        id="prompt-dir">~</span
      ><span class="text-white">$&nbsp;</span><input
        type="text"
        id="command-input"
        class="flex-1 bg-transparent text-white font-mono text-sm p-0 m-0 outline-none focus:outline-none border-none focus:border-none focus:ring-0"
        autocomplete="off"
        spellcheck="false"
        autofocus
      />
    </div>
  </div>

  <script is:inline define:vars={{ postsData }}>
    import("/src/lib/filesystem.ts").then(({ FileSystem }) => {
      // Initialize filesystem
      const fs = new FileSystem();
      let commandHistory = [];
      let historyIndex = -1;

      // DOM elements
      const terminalOutput = document.getElementById("terminal-output");
      const terminalContainer = document.getElementById("terminal-container");
      const commandInput = document.getElementById("command-input");
      const statusDir = document.getElementById("status-dir");
      const promptDir = document.getElementById("prompt-dir");
      const statusTime = document.getElementById("status-time");

      // Initialize filesystem and load state
      fs.init().then(async () => {
        // Add blog posts to filesystem
        for (const post of postsData) {
          const path = `/home/user/post/${post.id}.md`;
          if (!fs.exists(path)) {
            await fs.writeFile(path, "", false);
            fs.setFileData(path, post);
          }
        }

        // Load saved directory
        const cwd = await fs.loadCwd();
        updatePrompt();

        // Show welcome message
        showWelcome();
      });

      // Update time in status bar
      function updateTime() {
        const now = new Date();
        statusTime.textContent = now.toLocaleTimeString();
      }
      setInterval(updateTime, 1000);
      updateTime();

      // Add output to terminal
      function addOutput(html, className = "") {
        const div = document.createElement("div");
        div.className = className;
        div.innerHTML = html;
        terminalOutput.appendChild(div);
        // Scroll to bottom
        window.scrollTo(0, document.body.scrollHeight);
      }

      // Add command to terminal output
      function addCommandToOutput(cmd) {
        const currentDir = fs.pwd();
        const cmdDiv = document.createElement("div");
        cmdDiv.className = "mb-2";
        cmdDiv.innerHTML = `<span class="text-shell-blue">user@prateek.page</span><span class="text-shell-blue-light">:</span><span class="text-shell-accent">${currentDir}</span><span class="text-white">$&nbsp;</span>${cmd}`;
        terminalOutput.appendChild(cmdDiv);
      }

      // Update prompt directory
      function updatePrompt() {
        const currentDir = fs.pwd();
        promptDir.textContent = currentDir;
        statusDir.textContent = currentDir === "~" ? "~/" : currentDir + "/";
      }

      // Welcome message
      function showWelcome() {
        const welcome = `
<div class="mb-4 text-shell-text">
<div class="text-shell-accent font-bold text-lg mb-2">Welcome to the interactive shell!</div>

Type <span class="text-shell-blue font-bold">help</span> to see available commands.
Type <span class="text-shell-blue font-bold">ls</span> to list files and directories.

<div class="text-shell-text-dimmer mt-2">Hint: Try creating files with 'touch' or directories with 'mkdir'</div>
</div>
`;
        addOutput(welcome);
      }

      // Parse command with support for flags and redirects
      function parseCommand(input) {
        const parts = input.trim().split(/\s+/);
        const cmd = parts[0];
        const args = [];
        const flags = {};
        let redirect = null;

        for (let i = 1; i < parts.length; i++) {
          const part = parts[i];

          // Check for redirects
          if (part === ">" || part === ">>") {
            redirect = {
              type: part,
              target: parts[i + 1],
            };
            break;
          }

          // Check for flags
          if (part.startsWith("-")) {
            const flagName = part.slice(1);
            flags[flagName] = true;
          } else {
            args.push(part);
          }
        }

        return { cmd, args, flags, redirect };
      }

      // Commands implementation
      const commands = {
        help: async () => {
          return `
<div class="space-y-1">
  <div class="text-white font-bold mb-2">Available Commands:</div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-shell-text text-xs">
    <div><span class="text-shell-blue font-bold">help</span> - Show this help message</div>
    <div><span class="text-shell-blue font-bold">ls [-l]</span> - List directory contents</div>
    <div><span class="text-shell-blue font-bold">cat [file]</span> - Display file contents</div>
    <div><span class="text-shell-blue font-bold">cd [dir]</span> - Change directory</div>
    <div><span class="text-shell-blue font-bold">pwd</span> - Print working directory</div>
    <div><span class="text-shell-blue font-bold">mkdir [-p] [dir]</span> - Create directory</div>
    <div><span class="text-shell-blue font-bold">rmdir [dir]</span> - Remove empty directory</div>
    <div><span class="text-shell-blue font-bold">touch [file]</span> - Create/update file</div>
    <div><span class="text-shell-blue font-bold">rm [-rf] [path]</span> - Remove file/directory</div>
    <div><span class="text-shell-blue font-bold">cp [-r] [src] [dst]</span> - Copy file/directory</div>
    <div><span class="text-shell-blue font-bold">mv [src] [dst]</span> - Move/rename file</div>
    <div><span class="text-shell-blue font-bold">echo [text]</span> - Print text (use > or >> to redirect)</div>
    <div><span class="text-shell-blue font-bold">grep [pattern] [file]</span> - Search in file</div>
    <div><span class="text-shell-blue font-bold">find [path] [pattern]</span> - Find files</div>
    <div><span class="text-shell-blue font-bold">wc [file]</span> - Count lines, words, chars</div>
    <div><span class="text-shell-blue font-bold">head [-n N] [file]</span> - Show first N lines</div>
    <div><span class="text-shell-blue font-bold">tail [-n N] [file]</span> - Show last N lines</div>
    <div><span class="text-shell-blue font-bold">tree [-L N]</span> - Show directory tree</div>
    <div><span class="text-shell-blue font-bold">clear</span> - Clear terminal</div>
    <div><span class="text-shell-blue font-bold">reset</span> - Reset filesystem to default</div>
    <div><span class="text-shell-blue font-bold">whoami</span> - Display current user</div>
    <div><span class="text-shell-blue font-bold">neofetch</span> - System information</div>
    <div><span class="text-shell-blue font-bold">matrix</span> - Enter the matrix</div>
    <div><span class="text-shell-blue font-bold">cowsay [msg]</span> - ASCII cow says something</div>
    <div><span class="text-shell-blue font-bold">hack</span> - Initiate hacking sequence</div>
    <div><span class="text-shell-blue font-bold">sudo [cmd]</span> - Execute as superuser</div>
    <div><span class="text-shell-blue font-bold">exit</span> - Exit shell mode</div>
  </div>
</div>`;
        },

        ls: async (args, flags) => {
          try {
            const path = args[0] || ".";

            if (flags.l) {
              const entries = await fs.lsLong(path);
              let output = '<div class="space-y-1 text-xs">';
              for (const entry of entries) {
                const size = entry.size.toString().padStart(8);
                const date = entry.modified.toLocaleDateString();
                const name =
                  entry.type === "dir"
                    ? `<span class="text-shell-blue font-bold">${entry.name}/</span>`
                    : `<span class="text-shell-accent">${entry.name}</span>`;
                output += `<div>${size} ${date} ${name}</div>`;
              }
              output += "</div>";
              return output;
            } else {
              const entries = await fs.ls(path);
              let output = '<div class="space-y-1">';
              for (const name of entries) {
                const fullPath = path === "." ? name : `${path}/${name}`;
                const isDir = fs.isDirectory(fullPath);
                if (isDir) {
                  output += `<div class="text-shell-blue font-bold">${name}/</div>`;
                } else {
                  output += `<div class="text-shell-accent">${name}</div>`;
                }
              }
              output += "</div>";
              return output;
            }
          } catch (err) {
            return `<div class="text-red-500">ls: ${err.message}</div>`;
          }
        },

        pwd: async () => {
          return `<div class="text-white">${fs.pwd()}</div>`;
        },

        cd: async (args) => {
          try {
            const target = args[0] || "~";
            await fs.cd(target);
            updatePrompt();
            return "";
          } catch (err) {
            return `<div class="text-red-500">cd: ${err.message}</div>`;
          }
        },

        cat: async (args) => {
          if (!args[0]) {
            return '<div class="text-red-500">cat: missing file operand</div>';
          }

          const filename = args[0];

          // Check if it's a special file
          if (
            filename === "profile.txt" ||
            filename === "/home/user/profile.txt" ||
            filename === "~/profile.txt"
          ) {
            return `
<div class="flex gap-4 flex-col md:flex-row items-start">
  <img src="https://static.prateek.page/images/profile.jpg" alt="Prateek Kumar" class="w-32 h-32 rounded-lg border-2 border-shell-blue" />
  <div class="space-y-2 flex-1">
    <div class="text-white text-xl font-bold">Prateek Kumar</div>
    <div class="text-shell-text-dim">Software Engineer</div>
    <div class="text-shell-text-dimmer">Specialization: <span class="text-shell-blue">Rust</span> | <span class="text-shell-accent">JavaScript</span></div>
  </div>
</div>`;
          }

          if (
            filename === "projects.txt" ||
            filename === "/home/user/projects.txt" ||
            filename === "~/projects.txt"
          ) {
            return `
<div class="space-y-3">
  <div class="">
    <div class="font-bold text-white">Open-WBO-Inc</div>
    <div class="text-shell-text-dim text-sm">Open-WBO-Inc is a partial incomplete MaxSAT solver built on top of Open-WBO. Open-WBO is an extensible and modular open-source MaxSAT solver. Open-WBO-Inc got 1st place in 60s timeout track and 2nd place in 300s timeout track at MaxSAT Evaluations 2018.</div>
    <a href="https://github.com/sbjoshi/Open-WBO-Inc" target="_blank" class="text-shell-accent text-sm">[GitHub]</a>
  </div>
  <div class="">
    <div class="font-bold text-white">UTVPI-OA</div>
    <div class="text-shell-text-dim text-sm">Implementation of algorithms to compute overapproximations of polyhedra based on Linear Programming and Fourier-Motzkin elimination.</div>
    <a href="https://github.com/IITH-Compilers/UTVPI-OA" target="_blank" class="text-shell-accent text-sm">[GitHub]</a>
  </div>
  <div class="">
    <div class="font-bold text-white">Timetabler</div>
    <div class="text-shell-text-dim text-sm">A customizable timetabling software for educational institutions that encodes timetabling constraints as a SAT formula and solves them using a MaxSAT solver.</div>
    <a href="https://github.com/sukrutrao/Timetabler" target="_blank" class="text-shell-accent text-sm">[GitHub]</a>
    <a href="https://timetabler.readthedocs.io/" target="_blank" class="text-shell-accent text-sm ml-2">[Docs]</a>
  </div>
  <div class="">
    <div class="font-bold text-white">Autojudge</div>
    <div class="text-shell-text-dim text-sm">An implementation of an online judge that can be used for conducting programming contests as well as managing assignments in a university.</div>
    <a href="https://github.com/vbsinha/autojudge" target="_blank" class="text-shell-accent text-sm">[GitHub]</a>
    <a href="https://autojudge.readthedocs.io/" target="_blank" class="text-shell-accent text-sm ml-2">[Docs]</a>
  </div>
</div>`;
          }

          if (
            filename === "education.txt" ||
            filename === "/home/user/education.txt" ||
            filename === "~/education.txt"
          ) {
            return `
<div class="">
  <div class="text-white font-bold">B. Tech. (Honors) in Computer Science and Engineering</div>
  <div class="text-shell-text-dim">Indian Institute of Technology Hyderabad, India</div>
  <div class="text-shell-text-dimmer">2015-2019</div>
</div>`;
          }

          if (
            filename === "publications.txt" ||
            filename === "/home/user/publications.txt" ||
            filename === "~/publications.txt"
          ) {
            return `
<div class="space-y-3 text-xs">
  <div class="">
    <div class="text-white font-semibold">Open-WBO-Inc: Approximation Strategies for Incomplete Weighted MaxSAT.</div>
    <div class="text-shell-text-dimmer">Saurabh Joshi, Prateek Kumar, Sukrut Rao, Ruben Martins</div>
    <div class="text-shell-blue">JSAT 2019 (vol. 11)</div>
    <a href="https://content.iospress.com/download/journal-on-satisfiability-boolean-modeling-and-computation/sat190118?id=journal-on-satisfiability-boolean-modeling-and-computation%2Fsat190118" target="_blank" class="text-shell-accent">[PDF]</a>
  </div>
  <div class="">
    <div class="text-white font-semibold">An analysis of executable size reduction by LLVM passes.</div>
    <div class="text-shell-text-dimmer">Shalini Jain, Utpal Bora, Prateek Kumar, Vaibhav B. Sinha, Suresh Purini, Ramakrishna Upadrasta</div>
    <div class="text-shell-blue">CSIT 2019</div>
    <a href="https://link.springer.com/article/10.1007%2Fs40012-019-00248-5" target="_blank" class="text-shell-accent">[PDF]</a>
  </div>
  <div class="">
    <div class="text-white font-semibold">Approximation Strategies for Incomplete MaxSAT.</div>
    <div class="text-shell-text-dimmer">Saurabh Joshi, Prateek Kumar, Ruben Martins, Sukrut Rao</div>
    <div class="text-shell-blue">CP 2018</div>
    <a href="https://link.springer.com/content/pdf/10.1007/978-3-319-98334-9_15.pdf" target="_blank" class="text-shell-accent">[PDF]</a>
  </div>
  <div class="mt-2">
    <a href="https://scholar.google.co.in/citations?user=M1NFyhAAAAAJ&hl=en" target="_blank" class="text-shell-accent">[Google Scholar]</a>
  </div>
</div>`;
          }

          if (
            filename === "contact.txt" ||
            filename === "/home/user/contact.txt" ||
            filename === "~/contact.txt"
          ) {
            return `
<div class="space-y-2">
  <div class="text-white font-bold">Contact Information:</div>
  <div><a href="https://github.com/prateekkumarweb" target="_blank" class="text-shell-accent">GitHub: @prateekkumarweb</a></div>
  <div><a href="https://bsky.app/profile/prateek.page" target="_blank" class="text-shell-accent">Bluesky: @prateek.page</a></div>
  <div><a href="https://www.linkedin.com/in/prateekkumarweb/" target="_blank" class="text-shell-accent">LinkedIn: prateekkumarweb</a></div>
</div>`;
          }

          if (
            filename === ".secrets" ||
            filename === "/home/user/.secrets" ||
            filename === "~/.secrets"
          ) {
            return `
<div class="text-shell-accent">
  🔒 You found the secret file!
  
  Secret: I actually prefer tabs over spaces... just kidding! 😄
</div>`;
          }

          // Check if it's a blog post
          if (filename.endsWith(".md")) {
            try {
              const data = fs.getFileData(filename);
              if (data) {
                const date = new Date(data.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                });
                return `
<div class="space-y-2">
  <div class="text-white text-xl font-bold">${data.title}</div>
  <div class="text-shell-text-dimmer text-sm">${date}</div>
  <div class="mt-2">
    <a href="/post/${data.id}/" class="text-shell-accent">[Read full post]</a>
  </div>
</div>`;
              }
            } catch {}
          }

          // Try reading from filesystem
          try {
            const content = await fs.readFile(filename);
            if (content) {
              return `<div class="text-white whitespace-pre-wrap">${content}</div>`;
            } else {
              return `<div class="text-shell-text-dimmer">(empty file)</div>`;
            }
          } catch (err) {
            return `<div class="text-red-500">cat: ${err.message}</div>`;
          }
        },

        mkdir: async (args, flags) => {
          if (!args[0]) {
            return '<div class="text-red-500">mkdir: missing operand</div>';
          }
          try {
            await fs.mkdir(args[0], flags.p || false);
            return "";
          } catch (err) {
            return `<div class="text-red-500">mkdir: ${err.message}</div>`;
          }
        },

        rmdir: async (args) => {
          if (!args[0]) {
            return '<div class="text-red-500">rmdir: missing operand</div>';
          }
          try {
            await fs.rmdir(args[0]);
            return "";
          } catch (err) {
            return `<div class="text-red-500">rmdir: ${err.message}</div>`;
          }
        },

        touch: async (args) => {
          if (!args[0]) {
            return '<div class="text-red-500">touch: missing file operand</div>';
          }
          try {
            await fs.touch(args[0]);
            return "";
          } catch (err) {
            return `<div class="text-red-500">touch: ${err.message}</div>`;
          }
        },

        rm: async (args, flags) => {
          if (!args[0]) {
            return '<div class="text-red-500">rm: missing operand</div>';
          }
          try {
            const recursive = flags.r || flags.R || false;
            const force = flags.f || false;
            await fs.rm(args[0], recursive, force);
            return "";
          } catch (err) {
            return `<div class="text-red-500">rm: ${err.message}</div>`;
          }
        },

        cp: async (args, flags) => {
          if (args.length < 2) {
            return '<div class="text-red-500">cp: missing file operand</div>';
          }
          try {
            const recursive = flags.r || flags.R || false;
            await fs.cp(args[0], args[1], recursive);
            return "";
          } catch (err) {
            return `<div class="text-red-500">cp: ${err.message}</div>`;
          }
        },

        mv: async (args) => {
          if (args.length < 2) {
            return '<div class="text-red-500">mv: missing file operand</div>';
          }
          try {
            await fs.mv(args[0], args[1]);
            return "";
          } catch (err) {
            return `<div class="text-red-500">mv: ${err.message}</div>`;
          }
        },

        echo: async (args) => {
          return `<div class="text-white">${args.join(" ")}</div>`;
        },

        grep: async (args, flags) => {
          if (args.length < 2) {
            return '<div class="text-red-500">grep: missing operand</div>';
          }
          try {
            const pattern = args[0];
            const path = args[1];
            const recursive = flags.r || flags.R || false;
            const results = await fs.grep(pattern, path, recursive);

            if (results.length === 0) {
              return '<div class="text-shell-text-dimmer">No matches found</div>';
            }

            let output = '<div class="space-y-1 text-xs">';
            for (const result of results) {
              output += `<div><span class="text-shell-blue">${result.path}:${result.line}:</span> ${result.content}</div>`;
            }
            output += "</div>";
            return output;
          } catch (err) {
            return `<div class="text-red-500">grep: ${err.message}</div>`;
          }
        },

        find: async (args) => {
          if (args.length < 2) {
            return '<div class="text-red-500">find: usage: find [path] [pattern]</div>';
          }
          try {
            const path = args[0];
            const pattern = args[1];
            const results = await fs.find(path, pattern);

            if (results.length === 0) {
              return '<div class="text-shell-text-dimmer">No files found</div>';
            }

            let output = '<div class="space-y-1">';
            for (const result of results) {
              output += `<div class="text-shell-accent">${result}</div>`;
            }
            output += "</div>";
            return output;
          } catch (err) {
            return `<div class="text-red-500">find: ${err.message}</div>`;
          }
        },

        wc: async (args) => {
          if (!args[0]) {
            return '<div class="text-red-500">wc: missing file operand</div>';
          }
          try {
            const stats = await fs.wc(args[0]);
            return `<div class="text-white">${stats.lines} ${stats.words} ${stats.chars} ${args[0]}</div>`;
          } catch (err) {
            return `<div class="text-red-500">wc: ${err.message}</div>`;
          }
        },

        head: async (args, flags) => {
          if (!args[0]) {
            return '<div class="text-red-500">head: missing file operand</div>';
          }
          try {
            const lines = flags.n ? parseInt(flags.n) : 10;
            const content = await fs.head(args[0], lines);
            return `<div class="text-white whitespace-pre-wrap">${content}</div>`;
          } catch (err) {
            return `<div class="text-red-500">head: ${err.message}</div>`;
          }
        },

        tail: async (args, flags) => {
          if (!args[0]) {
            return '<div class="text-red-500">tail: missing file operand</div>';
          }
          try {
            const lines = flags.n ? parseInt(flags.n) : 10;
            const content = await fs.tail(args[0], lines);
            return `<div class="text-white whitespace-pre-wrap">${content}</div>`;
          } catch (err) {
            return `<div class="text-red-500">tail: ${err.message}</div>`;
          }
        },

        tree: async (args, flags) => {
          try {
            const path = args[0] || ".";
            const maxDepth = flags.L ? parseInt(flags.L) : Infinity;
            const treeStr = await fs.tree(path, maxDepth);
            return `<div class="text-white whitespace-pre font-mono text-xs">${treeStr}</div>`;
          } catch (err) {
            return `<div class="text-red-500">tree: ${err.message}</div>`;
          }
        },

        clear: async () => {
          terminalOutput.innerHTML = "";
          return null;
        },

        reset: async () => {
          try {
            await fs.reset();
            // Re-add blog posts
            for (const post of postsData) {
              const path = `/home/user/post/${post.id}.md`;
              if (!fs.exists(path)) {
                await fs.writeFile(path, "", false);
                fs.setFileData(path, post);
              }
            }
            updatePrompt();
            return `<div class="text-shell-accent">Filesystem reset to default state. All custom files and directories have been removed.</div>`;
          } catch (err) {
            return `<div class="text-red-500">reset: ${err.message}</div>`;
          }
        },

